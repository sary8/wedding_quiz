<mxfile host="app.diagrams.net" agent="wedding-quiz-docs" version="24.0.0">
  <diagram id="prod-arch" name="本番構成（prod）">
    <mxGraphModel dx="1420" dy="820" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1250" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="clients" value="会場のクライアント&lt;br&gt;&lt;b&gt;ゲストのスマホ（〜100台）&lt;/b&gt;&lt;br&gt;ホストPC / プロジェクター" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="230" width="200" height="90" as="geometry" />
        </mxCell>

        <mxCell id="rg" value="Azure（Japan West）/ リソースグループ quiz-prod" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#0078D4;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;fontColor=#0078D4;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="320" y="60" width="620" height="560" as="geometry" />
        </mxCell>

        <mxCell id="swa" value="Static Web Apps&lt;br&gt;&lt;b&gt;swa-quiz-prod&lt;/b&gt;（Free）&lt;br&gt;React SPA 配信" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="360" y="120" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="app" value="App Service&lt;br&gt;&lt;b&gt;quiz-prod&lt;/b&gt;（普段F1 / 当日B1）&lt;br&gt;Hono + Socket.io&lt;br&gt;システム割り当てマネージドID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
