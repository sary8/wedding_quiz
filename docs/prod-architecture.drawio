        </mxCell>

        <mxCell id="ai" value="Application Insights&lt;br&gt;&lt;b&gt;appi-quiz-prod&lt;/b&gt;&lt;br&gt;Live Metrics / KQL / 5GB無料枠" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="680" y="480" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="note" value="フロント→API 間は CORS（API側の CORS_ORIGIN）と&lt;br&gt;CSP connect-src / img-src（フロント側）で許可済み。&lt;br&gt;メディア応答は CORP: cross-origin を明示付与" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="360" y="460" width="280" height="70" as="geometry" />
        </mxCell>

        <mxCell id="turso" value="Turso（外部SaaS・無料枠）&lt;br&gt;libSQL / 東京リージョン&lt;br&gt;クイズ・参加者・回答データ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
