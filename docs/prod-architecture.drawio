        </mxCell>

        <mxCell id="kv" value="Key Vault&lt;br&gt;&lt;b&gt;kv-quiz-prod&lt;/b&gt;&lt;br&gt;ADMIN-PIN / DBトークン" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="680" y="120" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="st" value="Blob Storage&lt;br&gt;&lt;b&gt;stquizprod&lt;/b&gt; / コンテナ media&lt;br&gt;questions / choices / selfies" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
